---
import PageLayout from '@layouts/PageLayout.astro';
import { site, url } from '@data/site';
---

<PageLayout
  title={`Pagina Non Trovata | ${site.name}`}
  description="La pagina che stai cercando non esiste o è stata spostata."
  noindex={true}
>
  <section class="error-page">
    <div class="container">
      <span class="error-page__code">404</span>
      <h1 class="error-page__title">Pagina Non Trovata</h1>
      <p class="error-page__desc">
        La pagina che stai cercando non esiste o è stata spostata.
      </p>
      <div class="error-page__actions">
        <a href={url('/')} class="btn btn--primary btn--lg">Torna alla Home</a>
        <a href={url('/contatti/')} class="btn btn--outline btn--lg">Contattaci</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .error-page {
    min-height: calc(100dvh - 80px);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding-top: 80px;
  }

  .error-page__code {
    font-family: var(--font-display);
    font-size: clamp(6rem, 15vw, 12rem);
    font-weight: var(--weight-bold);
    color: rgba(198, 40, 40, 0.15);
    line-height: 1;
    display: block;
    margin-bottom: var(--space-16);
  }

  .error-page__title {
    font-size: var(--text-h1);
    margin-bottom: var(--space-16);
  }

  .error-page__desc {
    color: var(--text-secondary);
    font-size: var(--text-lg);
    margin-bottom: var(--space-32);
    max-width: 500px;
    margin-inline: auto;
  }

  .error-page__actions {
    display: flex;
    gap: var(--space-16);
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
