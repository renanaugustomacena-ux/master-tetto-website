---
import { footerNav } from '@data/navigation';
import { site, url } from '@data/site';
---

<footer class="footer section" style={`--footer-bg: url(${url('/images/bg-tetto-closeup.jpeg')})`}>
  <div class="container">
    <div class="footer__grid">
      <!-- Brand -->
      <div class="footer__brand">
        <span class="footer__logo-text">MASTER<strong>TETTO</strong></span>
        <p class="footer__tagline">{site.tagline}</p>
        <p class="footer__address">
          {site.address.street}<br />
          {site.address.postalCode}
          {site.address.city} ({site.address.province})
        </p>
      </div>

      <!-- Navigation -->
      <div class="footer__nav">
        <h4 class="footer__heading">Navigazione</h4>
        <ul role="list">
          {
            footerNav.map((link) => (
              <li>
                <a href={link.href} class="footer__link">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Contact -->
      <div class="footer__contact">
        <h4 class="footer__heading">Contatti</h4>
        <ul role="list">
          <li>
            <a href={`tel:${site.phone}`} class="footer__link">{site.phoneDisplay}</a>
          </li>
          <li>
            <a href={`mailto:${site.email}`} class="footer__link">{site.email}</a>
          </li>
          <li>
            <a href={site.whatsapp} class="footer__link" target="_blank" rel="noopener noreferrer">
              WhatsApp
            </a>
          </li>
        </ul>
      </div>

      <!-- Social -->
      <div class="footer__social">
        <h4 class="footer__heading">Social</h4>
        <div class="footer__social-links">
          {
            site.socialLinks.map((social) => (
              <a
                href={social.url}
                class="footer__social-link"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={social.label}
              >
                {social.label}
              </a>
            ))
          }
        </div>
      </div>
    </div>

    <hr class="divider" />

    <div class="footer__bottom">
      <p class="footer__legal">
        &copy; {new Date().getFullYear()}
        {site.legalName} &mdash; P.IVA {site.piva}
      </p>
      <div class="footer__bottom-links">
        <a href={url('/privacy/')} class="footer__link">Privacy Policy</a>
        <a href={url('/cookie/')} class="footer__link">Cookie Policy</a>
        <button class="footer__link footer__cookie-btn" id="manage-cookies" type="button"
          >Gestisci Cookie</button
        >
      </div>
    </div>
  </div>
</footer>

<script>
  document.getElementById('manage-cookies')?.addEventListener('click', () => {
    localStorage.removeItem('cookie_consent');
    const banner = document.getElementById('cookie-banner');
    if (banner) banner.hidden = false;
  });
</script>

<style>
  .footer {
    position: relative;
    background:
      linear-gradient(rgba(0, 0, 0, 0.8), rgba(0, 0, 0, 0.85)),
      var(--footer-bg) center / cover no-repeat;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    color: #fff;
  }

  .footer :global(h4),
  .footer :global(strong) {
    color: rgba(255, 255, 255, 0.95);
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--space-48);
    margin-bottom: var(--space-48);
  }

  .footer__logo-text {
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: var(--weight-light);
    letter-spacing: var(--tracking-wider);
    color: rgba(255, 255, 255, 0.95);
    text-transform: uppercase;
  }

  .footer__logo-text strong {
    font-weight: var(--weight-bold);
    color: var(--accent-primary);
  }

  .footer__tagline {
    margin-top: var(--space-8);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.6);
  }

  .footer__address {
    margin-top: var(--space-16);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.7);
    line-height: var(--leading-relaxed);
  }

  .footer__heading {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.95);
    margin-bottom: var(--space-16);
  }

  .footer__link {
    display: block;
    padding-block: var(--space-4);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.7);
    transition: color var(--duration-fast);
  }

  .footer__link:hover {
    color: var(--accent-primary);
  }

  .footer__social-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .footer__social-link {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.7);
    transition: color var(--duration-fast);
  }

  .footer__social-link:hover {
    color: var(--accent-primary);
  }

  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-32);
  }

  .footer__legal {
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.5);
  }

  .divider {
    border-color: rgba(255, 255, 255, 0.1);
  }

  .footer__bottom-links {
    display: flex;
    gap: var(--space-24);
  }

  .footer__cookie-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-body);
    padding-block: var(--space-4);
  }

  @media (max-width: 768px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-32);
    }

    .footer__brand {
      grid-column: 1 / -1;
    }

    .footer__bottom {
      flex-direction: column;
      gap: var(--space-16);
      text-align: center;
    }
  }

  @media (max-width: 480px) {
    .footer__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
