---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, description, align = 'center' } = Astro.props;
---

<div class:list={['section-header', `section-header--${align}`]} data-animate="fade-up">
  {eyebrow && <span class="eyebrow">{eyebrow}</span>}
  <h2 class="section-header__title" data-split>{title}</h2>
  {description && <p class="section-header__desc text-lead">{description}</p>}
</div>

<style>
  .section-header {
    margin-bottom: var(--space-64);
  }

  .section-header--center {
    text-align: center;
    max-width: 700px;
    margin-inline: auto;
  }

  .section-header--left {
    text-align: left;
  }

  .eyebrow {
    display: block;
    margin-bottom: var(--space-16);
  }

  .section-header__title {
    margin-bottom: var(--space-16);
  }

  .section-header__desc {
    max-width: 600px;
  }

  .section-header--center .section-header__desc {
    margin-inline: auto;
  }
</style>
