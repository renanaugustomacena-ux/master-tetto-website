---
import BaseLayout from './BaseLayout.astro';
import Nav from '@components/global/Nav.astro';
import Footer from '@components/global/Footer.astro';
import WhatsAppFloat from '@components/global/WhatsAppFloat.astro';
import BackToTop from '@components/global/BackToTop.astro';
import CookieBanner from '@components/global/CookieBanner.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  schema?: Record<string, unknown>;
}

const { title, description, canonical, ogImage, noindex, schema } = Astro.props;
const currentPath = Astro.url.pathname;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
  noindex={noindex}
  schema={schema}
>
  <Nav currentPath={currentPath} />
  <main id="main-content">
    <slot />
  </main>
  <Footer />
  <WhatsAppFloat />
  <BackToTop />
  <CookieBanner />
</BaseLayout>
